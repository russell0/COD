{
  "name": "cod-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "COD - Open Source Claude Code Implementation",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "changeset": "changeset",
