{
  "name": "cod",
  "version": "0.1.0",
  "description": "COD - Open Source Claude Code Implementation",
  "type": "module",
  "bin": {
    "cod": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "cli",
    "coding-assistant",
    "claude",
    "anthropic",
    "openai",
    "gemini",
    "llm"
  ],
  "author": "COD Contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cod-dev/cod.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0"
  },
  "dependencies": {
    "@cod/types": "workspace:*",
    "@cod/config": "workspace:*",
    "@cod/llm": "workspace:*",
    "@cod/tools": "workspace:*",
    "@cod/permissions": "workspace:*",
    "@cod/hooks": "workspace:*",
    "@cod/mcp": "workspace:*",
    "@cod/memory": "workspace:*",
    "@cod/session": "workspace:*",
    "@cod/agent": "workspace:*",
    "@cod/tui": "workspace:*",
    "commander": "^12.0.0",
    "zod": "^3.22.0",
    "execa": "^9.3.0",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "@anthropic-ai/sdk": "^0.26.0",
    "openai": "^4.52.0",
    "@google/generative-ai": "^0.15.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
